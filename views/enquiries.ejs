<%- include('partials/header', { title: 'Enquiries' }) %>

<div class="container mt-5">
    <h1>Enquiries</h1>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Subject</th>
                <th>Message</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% enquiries.forEach(enquiry => { %>
                <tr>
                    <td><%= enquiry.name %></td>
                    <td><%= enquiry.email %></td>
                    <td><%= enquiry.subject %></td>
                    <td><%= enquiry.message %></td>
                    <td>
                        <form action="/enquiries/<%= enquiry._id %>" method="POST" style="display: inline;">
                            <select name="status" onchange="this.form.submit()">
                                <option value="Open" <%= enquiry.status === 'Open' ? 'selected' : '' %>>Open</option>
                                <option value="In Progress" <%= enquiry.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                                <option value="Resolved" <%= enquiry.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                            </select>
                        </form>
                    </td>
                    <td><%= new Date(enquiry.createdAt).toLocaleDateString() %></td>
                    <td>
                        <!-- Add delete or other actions if needed -->
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>