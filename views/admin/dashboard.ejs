<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body>

<div class="sidebar">
    <div class="logo">
        <h2>SmartEvent</h2>
    </div>

    <nav>
        <a href="/admin/dashboard"><i class="fas fa-chart-line"></i> Dashboard</a>
        <a href="/events"><i class="fas fa-calendar-alt"></i> Events</a>
        <a href="/dashboard"><i class="fas fa-ticket-alt"></i> Bookings</a>
        <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </nav>
</div>

<div class="main-content">

    <!-- Top Bar -->
    <header class="topbar">
        <div>
            <h1>Dashboard Overview</h1>
            <p>Welcome back, Admin</p>
        </div>
        <div class="admin-profile">
            <i class="fas fa-user-circle"></i>
        </div>
    </header>

    <!-- Stat Cards -->
    <section class="cards">

        <div class="card users">
            <div>
                <h3>Total Users</h3>
                <p><%= totalUsers %></p>
            </div>
            <i class="fas fa-users"></i>
        </div>

        <div class="card events">
            <div>
                <h3>Total Events</h3>
                <p><%= totalEvents %></p>
            </div>
            <i class="fas fa-calendar-check"></i>
        </div>

        <div class="card bookings">
            <div>
                <h3>Total Bookings</h3>
                <p><%= totalBookings %></p>
            </div>
            <i class="fas fa-ticket"></i>
        </div>

        <div class="card revenue">
            <div>
                <h3>Total Revenue</h3>
                <p>R <%= totalRevenue %></p>
            </div>
            <i class="fas fa-dollar-sign"></i>
        </div>

    </section>

    <div class="table-header">
        <h2>Recent Events</h2>
        <button id="btn-new-event" class="view-btn">+ Create Event</button>
    </div>


    <!-- Events Table -->
    <section class="table-section">
        <div class="table-header">
            <h2>Recent Events</h2>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Capacity</th>
                    <th>Sold</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                <% events.forEach(event => { %>
                    <tr>
                        <td><%= event.title %></td>
                        <td><%= new Date(event.date).toDateString() %></td>
                        <td><%= event.capacity %></td>
                        <td><%= event.ticketsSold %></td>
                        <td>
                            <span class="status <%= event.status.toLowerCase() %>">
                                <%= event.status %>
                            </span>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </section>

</div>

<!-- MODAL: NEW EVENT FORM -->
<div class="modal-overlay" id="new-event-overlay">
  <div class="modal">
    <div class="modal-header">
      <h2>Create New Event</h2>
      <button class="modal-close" id="new-event-close">✕</button>
    </div>
    <div class="modal-body">
      <form id="newEventForm" class="detail-grid">
        <div class="detail-item">
          <label>Title</label>
          <input type="text" id="ev-title" name="title" required />
        </div>
        <div class="detail-item">
          <label>Date</label>
          <input type="date" id="ev-date" name="date" required />
        </div>
        <div class="detail-item">
          <label>Capacity</label>
          <input type="number" id="ev-capacity" name="capacity" required />
        </div>
        <div class="detail-item">
          <label>Status</label>
          <select id="ev-status" name="status">
            <option value="Upcoming">Upcoming</option>
            <option value="Active">Active</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
          </select>
        </div>
        <button type="submit" class="view-btn active" style="margin-top:1rem">Create Event</button>
      </form>
    </div>
  </div>
</div>

<script src="/scripts.js"">

</script>

</body>