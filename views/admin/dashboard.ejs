<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <link rel="stylesheet" href="/style.css">
</head>

<body>

<div class="sidebar">

    <div class="logo">
        <h2>SmartEvent</h2>
    </div>

    <nav>
        <a href="/admin/dashboard" class="active">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>

        <a href="/events">
            <i class="fas fa-calendar-alt"></i> Events
        </a>

        <a href="/bookings/admin">
            <i class="fas fa-ticket-alt"></i> Bookings
        </a>

        <a href="/logout">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </nav>

</div>

<div class="main-content">

    <!-- Top Bar -->
    <header class="topbar">

        <div>
            <h1>Dashboard Overview</h1>
            <p>Welcome back, Admin</p>
        </div>

        <div class="admin-profile">
            <i class="fas fa-user-circle"></i>
        </div>

    </header>

    <!-- Stat Cards -->
    <section class="cards">

        <div class="card users">
            <div>
                <h3>Total Users</h3>
                <p><%= totalUsers %></p>
            </div>

            <i class="fas fa-users"></i>
        </div>

        <div class="card events">
            <div>
                <h3>Total Events</h3>
                <p><%= totalEvents %></p>
            </div>

            <i class="fas fa-calendar-check"></i>
        </div>

        <div class="card bookings">
            <div>
                <h3>Total Bookings</h3>
                <p><%= totalBookings %></p>
            </div>

            <i class="fas fa-ticket"></i>
        </div>

        <div class="card revenue">
            <div>
                <h3>Total Revenue</h3>
                <p>R <%= totalRevenue %></p>
            </div>

            <i class="fas fa-dollar-sign"></i>
        </div>

    </section>

    <!-- Events Table -->
    <section class="table-section">

        <div class="table-header">
            <h2>Recent Events</h2>

            <button id="btn-new-event" class="view-btn">
                + Create Event
            </button>
        </div>

        <table>

            <thead>
                <tr>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Venue</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Capacity</th>
                    <th>Sold</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <% events.forEach(event => { %>

                    <tr>

                        <td><%= event.title %></td>

                        <td>
                            <%= new Date(event.date).toDateString() %>
                        </td>

                        <td><%= event.venue %></td>

                        <td><%= event.category %></td>

                        <td>
                            <%= event.ticketPrice === 0 ? 'Free' : 'R ' + event.ticketPrice %>
                        </td>

                        <td><%= event.capacity %></td>

                        <td><%= event.ticketsSold %></td>

                        <td>
                            <span class="status <%= event.status.toLowerCase() %>">
                                <%= event.status %>
                            </span>
                        </td>

                        <td style="display: flex; gap: 0.5rem;">

                            <!-- Edit Button -->
                            <button
                                class="view-btn btn-edit"
                                data-id="<%= event._id %>"
                                data-title="<%= event.title %>"
                                data-date="<%= event.date.toISOString().split('T')[0] %>"
                                data-venue="<%= event.venue %>"
                                data-description="<%= event.description %>"
                                data-category="<%= event.category %>"
                                data-capacity="<%= event.capacity %>"
                                data-price="<%= event.ticketPrice %>"
                                data-status="<%= event.status %>">

                                Edit

                            </button>

                            <!-- Delete Form -->
                            <form
                                action="/events/<%= event._id %>?_method=DELETE"
                                method="POST"
                                onsubmit="return confirm('Delete this event?')">

                                <button type="submit" class="cancel-btn">
                                    Delete
                                </button>

                            </form>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </section>

</div>

<!-- MODAL: CREATE EVENT -->
<div class="modal-overlay" id="new-event-overlay">

    <div class="modal">

        <div class="modal-header">
            <h2>Create New Event</h2>

            <button class="modal-close" id="new-event-close">
                ✕
            </button>
        </div>

        <div class="modal-body">

            <form id="newEventForm" class="detail-grid">

                <div class="detail-item">
                    <label>Title</label>

                    <input type="text" name="title" required />
                </div>

                <div class="detail-item">
                    <label>Description</label>

                    <textarea name="description" required></textarea>
                </div>

                <div class="detail-item">
                    <label>Date</label>

                    <input type="date" name="date" required />
                </div>

                <div class="detail-item">
                    <label>Venue</label>

                    <input type="text" name="venue" required />
                </div>

                <div class="detail-item">
                    <label>Category</label>

                    <select name="category" required>
                        <option value="">Select category</option>
                        <option value="Music">Music</option>
                        <option value="Sports">Sports</option>
                        <option value="Business">Business</option>
                        <option value="Technology">Technology</option>
                        <option value="Education">Education</option>
                    </select>
                </div>

                <div class="detail-item">
                    <label>Capacity</label>

                    <input type="number" name="capacity" min="1" required />
                </div>

                <div class="detail-item">
                    <label>Ticket Price (R)</label>

                    <input type="number" name="ticketPrice" min="0" value="0" required />
                </div>

                <div class="detail-item">
                    <label>Status</label>

                    <select name="status">
                        <option value="Upcoming">Upcoming</option>
                        <option value="Active">Active</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <button type="submit" class="view-btn active" style="margin-top: 1rem;">
                    Create Event
                </button>

            </form>

        </div>

    </div>

</div>

<!-- MODAL: EDIT EVENT -->
<div class="modal-overlay" id="edit-event-overlay">

    <div class="modal">

        <div class="modal-header">
            <h2>Edit Event</h2>

            <button class="modal-close" id="edit-event-close">
                ✕
            </button>
        </div>

        <div class="modal-body">

            <form id="editEventForm" class="detail-grid">

                <input type="hidden" id="edit-id" />

                <div class="detail-item">
                    <label>Title</label>

                    <input type="text" id="edit-title" name="title" required />
                </div>

                <div class="detail-item">
                    <label>Description</label>

                    <textarea id="edit-description" name="description" required></textarea>
                </div>

                <div class="detail-item">
                    <label>Date</label>

                    <input type="date" id="edit-date" name="date" required />
                </div>

                <div class="detail-item">
                    <label>Venue</label>

                    <input type="text" id="edit-venue" name="venue" required />
                </div>

                <div class="detail-item">
                    <label>Category</label>

                    <select id="edit-category" name="category" required>
                        <option value="Music">Music</option>
                        <option value="Sports">Sports</option>
                        <option value="Business">Business</option>
                        <option value="Technology">Technology</option>
                        <option value="Education">Education</option>
                    </select>
                </div>

                <div class="detail-item">
                    <label>Capacity</label>

                    <input type="number" id="edit-capacity" name="capacity" min="1" required />
                </div>

                <div class="detail-item">
                    <label>Ticket Price (R)</label>

                    <input type="number" id="edit-price" name="ticketPrice" min="0" required />
                </div>

                <div class="detail-item">
                    <label>Status</label>

                    <select id="edit-status" name="status">
                        <option value="Upcoming">Upcoming</option>
                        <option value="Active">Active</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>

                <button type="submit" class="view-btn active" style="margin-top: 1rem;">
                    Save Changes
                </button>

            </form>

        </div>

    </div>

</div>

<script src="/scripts.js"></script>

<script>

(function () {

    // Open Create Modal
    document.getElementById('btn-new-event')
        .addEventListener('click', function () {

            document.getElementById('new-event-overlay').style.display = 'flex';
        });

    // Close Create Modal
    document.getElementById('new-event-close')
        .addEventListener('click', function () {

            document.getElementById('new-event-overlay').style.display = 'none';
        });

})();

</script>

</body>
</html>