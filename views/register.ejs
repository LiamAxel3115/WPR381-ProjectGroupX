<!--we want the header and nav from the header.ejs to be in the register,ejs web page - no writing repeated code continuously-->
<%- include('partials/header', { title: 'Register' }) %>

<!--creation of form - where the user either creates an account or log ins-->
<div class="row justify-content-center">
    <div class="col-md-6">
        <h1>Create an Account</h1>
        <form action ="/register" method="POST">
            <div class="mb-3">
                <label for="name" class="form-label">Full Name</label>
                <input type="text" class="form-control" id="name" name="name" required>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" required>
            </div>
            <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm Password</label>
                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
            </div>
            <button type="submit" class="btn btn-primary">Register</button>
        </form>
        <!--without entering any required - no point in creating account/registering-->
        <p class="mt-3">Already have an account? <a href="/auth/login">Login here</a></p>
    </div>
</div>


