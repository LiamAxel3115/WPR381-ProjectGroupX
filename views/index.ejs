<!DOCTYPE html>
<html lang="en">
<head>

    <!-- Character encoding -->
    <meta charset="UTF-8">

    <!-- Responsive design settings -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Browser tab title -->
    <title>Smart Event Platform</title>

</head>
<body>
    <%- include('partials/header', { title: 'Home' }) %>

    <!--Coverage of the hero section (attraction)-->
    <section class="hero-section" aria-labelledby="hero-heading">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <span class="live-dot" aria-hidden="true"></span>Live Events - Book Instantly!
                </div>

                <h1 id="hero-heading" class="hero-title">Find &amp; Book<br><span class="hero-title-highlight">Amazing Events</span></h1>

                <p class="hero-description">
                    Discover unforgettable experiences across South Africa. From concerts to conferences, we connect you with the best events around. Book your next adventure today!
                </p>
                <div class="hero-cta d-flex flex-wrap gap-3">
                    <a href="#events-section" class="btn btn-warning btn-lg fw-fold px-4"><i class="bi bi-ticket-perfortated-fill me-2" aria-hidden="true"></i>Browse Events</a>
                </div>

                <!--show "get started" if the user is not logged in-->
                <% if (!locals.user) { %>
                        <a href="/register" class="btn btn-outline-light btn-lg px-4">Create Free Account</a>
                <% } %>    
            </div>
        </div>

        <div class="col-lg-5 mt-5 mt-lg-0">
            <div class="row g-3">

                        <!-- Stat card 1 -->
                        <div class="col-6">
                            <article class="stat-card" aria-label="Events statistic">
                                <div class="stat-icon">🎭</div>
                                <div class="stat-number">100+</div>
                                <div class="stat-label">Events Listed</div>
                            </article>
                        </div>

                        <!-- Stat card 2 -->
                        <div class="col-6">
                            <article class="stat-card" aria-label="Tickets statistic">
                                <div class="stat-icon">🎫</div>
                                <div class="stat-number">2,000+</div>
                                <div class="stat-label">Tickets Booked</div>
                            </article>
                        </div>

                        <!-- Stat card 3 -->
                        <div class="col-6">
                            <article class="stat-card" aria-label="Cities statistic">
                                <div class="stat-icon">📍</div>
                                <div class="stat-number">9</div>
                                <div class="stat-label">Cities</div>
                            </article>
                        </div>

                        <!-- Stat card 4 -->
                        <div class="col-6">
                            <article class="stat-card"  aria-label="Rating statistic">
                                <div class="stat-icon">⭐</div>
                                <div class="stat-number">4.9</div>
                                <div class="stat-label">Avg Rating</div>
                            </article>
                        </div>

                    </div><!-- end row -->
                </div><!-- end col -->

            </div><!-- end row -->
        </div><!-- end container -->
    </section>

    <div class="row">
        <div class="col-md-8">
            <!-- Main system heading - going to the search bar -->
            <h1>Smart Event Management Platform</h1>
        </div>
        <div class="col-md-4">
            <!--we create a search and filter-->
            <form action="/" method="GET" class="search-bar">
                <div class="row g-2 align-items-end w-100">
                    <div class="col-md-5">
                        <label for="searchInput" class="form-label small fw-semibold text-muted text-uppercase">Search events</label>

                        <input class="form-control me-2" type="search" name="search" id="searchInput" placeholder="Search events..." aria-label="Search events" value="<%= typeof search !== 'undefined' ? search : '' %>">
                    </div>

                    <!--category dropdown-->
                    <div class="col-md-4">
                        <label for="categorySelect" class="form-label small fw-semibold text-muted text-uppercase">Category</label>

                        <select class="form-select me-2" id="categoryList" name="category" aria-label="Filter by category">
                            <option value="">All Categories</option>
                            <option value="music" <%= typeof category !== 'undefined' && category === 'music' ? 'selected' : '' %>>🎵 Music</option>
                            <option value="sports" <%= typeof category !== 'undefined' && category === 'sports' ? 'selected' : '' %>>🏆 Sports</option>
                            <option value="theatre" <%= typeof category !== 'undefined' && category === 'theatre' ? 'selected' : '' %>>🎭 Theatre</option>
                            <option value="conference" <%= typeof category !== 'undefined' && category === 'conference' ? 'selected' : '' %>>💼 Conference</option>
                            <option value="workshop" <%= typeof category !== 'undefined' && category === 'workshop' ? 'selected' : '' %>>🛠 Workshop</option>
                            <option value="festival" <%= typeof category !== 'undefined' && category === 'festival' ? 'selected' : '' %>>🎪 Festival</option>
                        </select>
                    </div>
                    <!--buttons-->
                    <div class="col-md-3 d-flex gap-2">
                        <button class="btn btn-warning btn-lg fw-bold flex-grow-1" type="submit">Search</button>
                        <!--clear button to reset search-->
                        <a href="/" class="btn btn-outline-secondary btn-lg" aria-label="Clear search"></a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!--creation of the event-cards-->
    <section class="events-section py-5" id="events-section" aria-labelledby="evets-heading">
        <div class="container">
            <div class="section-header mb-4">
               <h2 id="events-heading" class="visually-hidden">Upcoming events</h2>
               <p class="section-description">Discover all the events and what's happening near you</p> 
            </div>
        </div>

        <!--checking if all the events exist-->
        <% if (locals.events && events.length > 0) { %>
            <% events.forEach(event => { %>
                <div class="col-lg-4 col-md-6">
                    <article class="card event-card h-100">
                        <div class="event-card-badge">
                            <%= event.category || 'Event' %>
                        </div>
                        <div class="event-card-img" aria-hidden="true">
                            <span class="event-emoji">
                                <% if (event.category === 'music')      { %>🎵
                                <% } else if (event.category === 'sports')     { %>🏆
                                <% } else if (event.category === 'conference') { %>💼
                                <% } else if (event.category === 'workshop')   { %>🛠
                                <% } else if (event.category === 'festival')   { %>🎪
                                <% } else if (event.category === 'theatre')    { %>🎭
                                <% } else { %>🎟️<% } %>        
                            </span>
                        </div>
                        <div class="event-card-body">
                            <h3 class="event-card-title"><%= event.name %></h3>
                            <p class="event-card-description"><%= event.description ? event.description.substring(0,80) + '...' : 'No description available.' %></p>

                            <!--event metadata-->
                            <ul class="event-mets list-unstyled" aria-label="Event details">
                                <li>
                                    <i class="bi bi-calendar3 me-2" aria-hidden="true"></i>
                                    <time datetime="<%= event.date.toISOString ? event.date.toISOString().split('T')[0] : '' %>"><%= event.date.toDateString ? event.date.toDateString() : event.date %></time>
                                </li>
                                <li>
                                    <i class="bi bi-geo-alt me-2" aria-hidden="true"></i>
                                    <%= event.location || 'Venue TBA'%>
                                </li>
                                <li>
                                    <i class="bi bi-people me-2" aria-hidden="true"></i>
                                    <%= event.availableTickets %> tickets left
                                </li>
                            </ul>

                            <!--card footer - price and button-->
                            <div class="event-card-footer">
                                <div class="event-price">
                                    R<%= event.price ? event.price.toFixed(2) : '0.00' %>
                                </div>
                                <a href="/events/<%= event._id %>" class="btn btn-warning btn-sm fw-bold">
                                    Book Now <i class="bi bi-arrow-right" aria-hidden="true"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                </div> 
                <% }) %>
            </div>  
        <% } else { %>
            <div class="empty-state text-center py-5" role="status">
                <div class="empty-state-icon" aria-hidden="true">😔</div>
                <h3>No events found.</h3>
                <p class="text-muted">Try adjustin your search or check back later for new events.</p>
                <a href="/" class="btn btn-warning fw-bold mt-2"><i class="bi bi-arrow-counterclockwise me-1"></i>Clear Filters</a>
            </div>
            
        <% } %>
    </section>
    
    <!-- ===================== WHY US SECTION ===================== -->
    <section class="why-section py-5" aria-labelledby="why-heading">
        <div class="container">

            <div class="section-header text-center mb-5">
                <h2 id="why-heading" class="section-title">Why Choose Smart Events?</h2>
            </div>

            <div class="row g-4 text-center">

                <!-- Feature 1 -->
                <div class="col-md-4">
                    <article class="feature-card" aria-label="Instant booking feature">
                        <div class="feature-icon" aria-hidden="true">⚡</div>
                        <h3 class="feature-title">Instant Booking</h3>
                        <p class="feature-desc">Book your tickets in seconds. No queues, no hassle.</p>
                    </article>
                </div>

                <!-- Feature 2 -->
                <div class="col-md-4">
                    <article class="feature-card" aria-label="Secure payments feature">
                        <div class="feature-icon" aria-hidden="true">🔒</div>
                        <h3 class="feature-title">Secure &amp; Safe</h3>
                        <p class="feature-desc">Your data is protected with industry-standard security.</p>
                    </article>
                </div>

                <!-- Feature 3 -->
                <div class="col-md-4">
                    <article class="feature-card" aria-label="All events feature">
                        <div class="feature-icon" aria-hidden="true">🗓️</div>
                        <h3 class="feature-title">All Event Types</h3>
                        <p class="feature-desc">Festivals, conferences, workshops — all in one place.</p>
                    </article>
                </div>

            </div><!-- end row -->
        </div><!-- end container -->
    </section>
    <!-- ===================== END WHY US ===================== -->
    <!-- Basic server status message -->
    <p>Server is working successfully.</p>

<%- include('partials/footer') %>

</body>

</html>