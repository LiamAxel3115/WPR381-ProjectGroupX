<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Dashboard</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="sidebar">
    <div class="logo">
        <h2>SmartEvent</h2>
    </div>

    <nav>
        <a href="/dashboard"><i class="fas fa-home"></i> Dashboard</a>
        <a href="/events"><i class="fas fa-calendar-alt"></i> Browse Events</a>
        <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </nav>
</div>

<div class="main-content">

    <!-- Topbar -->
    <header class="topbar">
        <div>
            <h1>My Bookings</h1>
            <p>Manage your events and ticket history</p>
        </div>

        <div class="admin-profile">
            <i class="fas fa-user-circle"></i>
        </div>
    </header>

    <!-- Stats -->
    <section class="cards">

        <div class="card users">
            <div>
                <h3>Total Bookings</h3>
                <p><%= bookings.length %></p>
            </div>
            <i class="fas fa-ticket-alt"></i>
        </div>

        <div class="card revenue">
            <div>
                <h3>Total Spent</h3>
                <p>
                    R <%= bookings
                        .filter(b => b.status === 'Confirmed')
                        .reduce((sum, b) => sum + b.totalPrice, 0) %>
                </p>
            </div>
            <i class="fas fa-wallet"></i>
        </div>

    </section>

    <!-- Bookings Table -->
    <section class="table-section">
        <div class="table-header">
            <h2>Booking History</h2>
        </div>

        <% if (bookings.length === 0) { %>
            <p>You have no bookings yet.</p>
        <% } else { %>

        <table>
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Tickets</th>
                    <th>Total Price</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                <% bookings.forEach(booking => { %>
                    <tr>
                        <td><%= booking.event ? booking.event.title : 'Event Removed' %></td>
                        <td>
                            <%= booking.event && booking.event.date
                                ? new Date(booking.event.date).toDateString()
                                : 'N/A' %>
                        </td>
                        <td><%= booking.ticketQuantity %></td>
                        <td>R <%= booking.totalPrice %></td>
                        <td>
                            <span class="status <%= booking.status.toLowerCase() %>">
                                <%= booking.status %>
                            </span>
                        </td>
                        <td>
                            <% if (booking.status === 'Confirmed') { %>
                                <form action="/bookings/<%= booking._id %>/cancel" method="POST">
                                    <button class="cancel-btn" type="submit">
                                        Cancel
                                    </button>
                                </form>
                            <% } else { %>
                                -
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <% } %>

    </section>

</div>

</body>
</html>